# ========== 数据库配置 ==========
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_database_password
DB_NAME=dorm_cleaning
DB_SOCKET=/tmp/mysql.sock

# ========== QQ邮箱 SMTP 配置 ==========
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your_email@qq.com
SMTP_PASS=your_smtp_authorization_code

# ========== 超级管理员（就是你） ==========
SUPER_ADMIN_EMAIL=your_email@qq.com

# ========== 应用配置 ==========
NUXT_PORT=3000
NUXT_PUBLIC_URL=http://localhost:3000
